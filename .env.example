# HERO Software API Token (Bearer-Token, vom HERO-Support ausgestellt)
HERO_API_TOKEN=

# Login fuer das Dashboard (App-eigener Schutz, nicht HERO-Login)
# WICHTIG: Next.js fuehrt $VAR-Expansion in .env-Werten durch. Jedes "$" im
# bcrypt-Hash (z.B. $2b$10$...) MUSS daher als "\$" escaped werden,
# sonst wird der Hash-Praefix entfernt und der Login schlaegt fehl.
APP_USERNAME=
APP_PASSWORD_HASH=

# Secret zum Signieren der Session-Cookies (zufaellig generiert, z.B. via:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AUTH_SECRET=
