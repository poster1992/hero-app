# HERO Software API Token (Bearer-Token, vom HERO-Support ausgestellt)
HERO_API_TOKEN=

# Login fuer das Dashboard (App-eigener Schutz, nicht HERO-Login)
# WICHTIG: Next.js fuehrt $VAR-Expansion in .env-Werten durch. Jedes "$" im
# bcrypt-Hash (z.B. $2b$10$...) MUSS daher als "\$" escaped werden,
# sonst wird der Hash-Praefix entfernt und der Login schlaegt fehl.
APP_USERNAME=
APP_PASSWORD_HASH=

# Secret zum Signieren der Session-Cookies (zufaellig generiert, z.B. via:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AUTH_SECRET=

# MySQL-Datenbank fuer den Login (Benutzerverwaltung)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# SMTP fuer E-Mail-Benachrichtigungen (z.B. all-inkl: wXXXXXX.kasserver.com,
# Port 587 STARTTLS oder 465 SSL; SMTP_USER/PASS = ein E-Mail-Postfach)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Basis-URL der App fuer Links in den E-Mails (optional, z.B. http://192.168.0.10:3000)
APP_URL=
